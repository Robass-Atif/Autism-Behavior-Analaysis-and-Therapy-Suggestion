    {
      "name": "Registration",
      "item": [
        {
          "name": "Register Therapist",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data._id) {",
                  "    pm.collectionVariables.set('userId', jsonData.data._id);",
                  "}",
                  "",
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response indicates pending verification', function () {",
                  "    pm.expect(jsonData.data.accountStatus).to.eql('pending_verification');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Dr. John Smith\",\n  \"professionalTitle\": \"Clinical Psychologist\",\n  \"email\": \"john.smith@clinic.com\",\n  \"phoneNumber\": \"+1234567890\",\n  \"credentials\": {\n    \"licenseNumber\": \"PSY-12345\",\n    \"licenseType\": \"Clinical Psychologist License\",\n    \"issuingAuthority\": \"State Board of Psychology\",\n    \"licenseExpiryDate\": \"2025-12-31\"\n  },\n  \"organization\": {\n    \"organizationName\": \"ABC Therapy Center\",\n    \"department\": \"Child Psychology\",\n    \"workAddress\": \"123 Medical Plaza, Suite 456\",\n    \"city\": \"New York\",\n    \"stateProvince\": \"NY\",\n    \"zipPostalCode\": \"10001\",\n    \"country\": \"USA\"\n  },\n  \"password\": \"SecurePass@123\",\n  \"confirmPassword\": \"SecurePass@123\",\n  \"termsAccepted\": true,\n  \"hipaaAccepted\": true,\n  \"privacyPolicyAccepted\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register/therapist",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register", "therapist"]
            },
            "description": "Register a new therapist with professional credentials"
          },
          "response": []
        },
