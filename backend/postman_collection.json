    {
      "name": "Invitations (Therapist Only)",
      "item": [
        {
          "name": "Create Invitation (with Email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{therapistToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"therapistName\": \"Dr. John Smith\",\n  \"recipientEmail\": \"caregiver@email.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/invitations",
              "host": ["{{baseUrl}}"],
              "path": ["invitations"]
            },
            "description": "Create invitation and send email"
          },
          "response": []
        },
        {
          "name": "Create Invitation (Code Only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{therapistToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"therapistName\": \"Dr. John Smith\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/invitations",
              "host": ["{{baseUrl}}"],
              "path": ["invitations"]
            },
            "description": "Create invitation code without sending email"
          },
          "response": []
        },
        {
          "name": "Get My Invitations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{therapistToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/invitations",
              "host": ["{{baseUrl}}"],
              "path": ["invitations"]
            },
            "description": "Get all invitations created by therapist"
          },
          "response": []
        },
        {
          "name": "Validate Invitation Code",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/invitations/validate/ABC12345",
              "host": ["{{baseUrl}}"],
              "path": ["invitations", "validate", "ABC12345"]
            },
            "description": "Validate an invitation code (public endpoint)"
          },
          "response": []
        },
        {
          "name": "Resend Invitation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{therapistToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/invitations/:invitationId/resend",
              "host": ["{{baseUrl}}"],
              "path": ["invitations", ":invitationId", "resend"],
              "variable": [
                {
                  "key": "invitationId",
                  "value": "invitation-id-here"
                }
              ]
            },
            "description": "Resend invitation email and extend expiration"
          },
          "response": []
        },
        {
          "name": "Revoke Invitation",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{therapistToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/invitations/:invitationId",
              "host": ["{{baseUrl}}"],
              "path": ["invitations", ":invitationId"],
              "variable": [
                {
                  "key": "invitationId",
                  "value": "invitation-id-here"
                }
              ]
            },
            "description": "Revoke an unused invitation"
          },
          "response": []
        }
      ]
    },
