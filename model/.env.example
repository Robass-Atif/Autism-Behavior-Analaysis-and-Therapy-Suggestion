# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=100

# Feature Flags
# Enable/disable 3D pose estimation and prediction
# Set to "false" or "0" to disable 3D processing (only 2D will be used)
# Set to "true" or "1" to enable both 2D and 3D processing
ENABLE_3D_PROCESSING=true
API_KEY=your-api-key-change-this-in-production

# Logging
LOG_LEVEL=INFO

# CORS (comma-separated list of allowed origins)
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
